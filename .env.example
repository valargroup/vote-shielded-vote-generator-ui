# Shielded-Vote chain REST API URL.
# Used as the default chain URL in the UI and as the Vite dev-server proxy target.
# Default: http://localhost:1318
VITE_CHAIN_URL=http://localhost:1318

# Lightwalletd gRPC-web endpoint for Zcash mainnet.
# Used as the default RPC endpoint for chain height / note scanning.
# Default: https://us.zec.stardust.rest (first entry in the built-in endpoint list)
VITE_LIGHTWALLETD_RPC=https://us.zec.stardust.rest

# Nullifier service base URL (no trailing slash).
# In dev mode (Vite), leave unset — requests proxy through the dev server to localhost:3000.
# In production (e.g. Vercel), set to the Caddy proxy URL:
#   VITE_NULLIFIER_URL=https://46-101-255-48.sslip.io/nullifier
VITE_NULLIFIER_URL=

# Vote manager private key (hex). Auto-populated by `mise run start` from vote-sdk/.env.
# The admin UI auto-connects with this key on page load.
VITE_VM_PRIVKEY=
